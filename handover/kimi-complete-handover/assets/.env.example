# ============================================================
# Alpha Labs - Environment Variables
# 
# INSTRUKTIONEN:
# 1. Kopiere diese Datei zu .env:  cp .env.example .env
# 2. Fuelle alle Pflicht-Variablen mit echten Werten aus
# 3. .env NIE in Git committen (steht in .gitignore)
# 4. Alle mit [*] markierten sind PFLICHT
# ============================================================

# ============================================================
# OPENAI - Pflicht fuer CreatorFuel KI-System [*]
# ============================================================
# Holt euch hier: https://platform.openai.com/api-keys
# Kosten: Pay-per-use, ca. $0.001-0.03 pro Post
# Format: sk-proj-... oder sk-...
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Welches Modell verwenden
# Optionen: gpt-4o-mini (guenstiger), gpt-4o (besser), gpt-4 (beste Qualitaet)
OPENAI_MODEL=gpt-4o-mini

# ============================================================
# CREATORFUEL - System-Konfiguration
# ============================================================
# Optional: Standardsprache fuer generierte Posts
# Optionen: de (Deutsch), en (Englisch), both (Beides)
DEFAULT_LANGUAGE=both

# Optional: Ausgabeverzeichnis fuer generierte Posts
OUTPUT_DIR=/mnt/agents/output/creatorfuel/posts

# ============================================================
# STRIPE - Zahlungsabwicklung (Phase 1+)
# ============================================================
# Hinweis: Die CreatorFuel-Produkte verwenden Stripe Payment Links.
# Diese werden im Stripe Dashboard erstellt und in die Landingpage
# eingetragen. Keine API-Keys noetig fuer den Basiskontakt.
# 
# Account erstellen: https://dashboard.stripe.com/register
# Payment Links erstellen unter: Dashboard -> Payment Links
# 
# Optional: Stripe API Keys fuer automatisierte Zahlungsabwicklung
# (Nur benoetigt wenn du eigene Checkout-Integration baust)
# STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ============================================================
# TWITTER/X - Social Media Marketing (Phase 2+)
# ============================================================
# Optional: Fuer automatisiertes Posting von Alpha Signal Threads
# Account: https://developer.twitter.com/en/portal/dashboard
# TWITTER_API_KEY=your-twitter-api-key
# TWITTER_API_SECRET=your-twitter-api-secret
# TWITTER_ACCESS_TOKEN=your-access-token
# TWITTER_ACCESS_TOKEN_SECRET=your-access-token-secret
# TWITTER_BEARER_TOKEN=AAAAAAAAAA...

# ============================================================
# NEWSLETTER - Versand-Plattform (Phase 2+)
# ============================================================
# Optional: Fuer automatisierten Newsletter-Versand
# Empfohlen: Beehiiv (https://www.beehiiv.com/) oder Substack
# BEEHIIV_API_KEY=your-beehiiv-api-key
# BEEHIIV_PUBLICATION_ID=your-publication-id

# ============================================================
# GOOGLE ANALYTICS - Website-Tracking (Optional)
# ============================================================
# Optional: Fuer Landingpage-Analytics
# Tracking-ID von https://analytics.google.com/
# GA_TRACKING_ID=G-XXXXXXXXXX

# ============================================================
# ZAPIER - Automatisierung (Phase 2+)
# ============================================================
# Optional: Fuer No-Code Automatisierungen
# ZAPIER_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/.../.../

# ============================================================
# ALLGEMEIN / SYSTEM
# ============================================================
# Optional: Umgebung (development, staging, production)
NODE_ENV=development

# Optional: Logging-Level (debug, info, warn, error)
LOG_LEVEL=info
