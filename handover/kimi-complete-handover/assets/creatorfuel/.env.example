# CreatorFuel - Umgebungsvariablen
# Kopiere diese Datei nach .env und trage deine Werte ein

# OpenAI API Key (erforderlich fuer KI-Generierung)
# Hol dir deinen Key hier: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# OpenAI Modell (optional)
# gpt-4o-mini = schnell & guenstig (empfohlen)
# gpt-4o = hoechste Qualitaet
OPENAI_MODEL=gpt-4o-mini

# Standardsprache fuer Posts
# de = Deutsch
# eng = Englisch
# both = Beides
DEFAULT_LANGUAGE=both

# Ausgabeverzeichnis (optional)
OUTPUT_DIR=/mnt/agents/output/creatorfuel/posts
